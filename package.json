{
  "name": "fiap-soat-tech-challenge-lambda",
  "version": "1.0.0",
  "description": "FIAP Tech Challenge - Lambda Document Authentication",
  "main": "dist/handler.js",
  "scripts": {
    "build": "tsc",
    "bundle": "esbuild src/handler.ts --bundle --platform=node --target=node22 --outfile=dist/handler.js --minify",
    "package": "npm run bundle && cd dist && zip -r lambda.zip handler.js && cd ..",
    "test": "jest --runInBand --silent",
    "test:coverage": "jest --runInBand --coverage --silent"
  },
  "dependencies": {
    "@aws-sdk/client-ssm": "^3.600.0",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.145",
    "@types/jest": "^29.5.11",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.0.0",
    "@types/pg": "^8.11.6",
    "esbuild": "^0.28.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.9.3"
  }
}
